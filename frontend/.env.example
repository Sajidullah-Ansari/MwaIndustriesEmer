# MWA Industries Frontend Environment Variables
# Copy this file to .env and update the values

# Backend API URL - Update this to your deployed backend URL
# For local development: http://localhost:8001
# For production: https://your-backend-domain.com
REACT_APP_BACKEND_URL=http://localhost:8001

# WebSocket port (for development)
WDS_SOCKET_PORT=443

# Enable health check (set to false for production)
ENABLE_HEALTH_CHECK=false
